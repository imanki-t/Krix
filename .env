# Your GitHub Personal Access Token (fine-grained recommended).
# Used as the default token when a request doesn't supply its own.
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: only needed for GitHub Enterprise Server
# GITHUB_BASE_URL=https://github.mycompany.com/api/v3

# Optional shared secret. If set, clients must send:
# Authorization: Bearer <this value>
MCP_AUTH_TOKEN=change-me-to-a-long-random-string

PORT=3000
