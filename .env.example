# Server port configuration (defaults to 3000 if not set)
PORT=3000

# Secure access token for this MCP gateway. Clients must send this via headers to authenticate.
MCP_API_KEY=your_mcp_gateway_security_key_here

# GitHub Personal Access Token with repo scope permissions
GITHUB_PAT=ghp_your_github_token_here

# Render API Key. Optional; if empty, Render features automatically disable to save baseline tokens.
RENDER_PAT=rnd_your_render_api_key_here
